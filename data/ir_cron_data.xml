<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!-- Cron job for processing scheduled messages -->
        <record id="ir_cron_process_scheduled_messages" model="ir.cron">
            <field name="name">پردازش پیام‌های تلگرام</field>
            <field name="model_id" ref="model_telegram_scheduled_message"/>
            <field name="state">code</field>
            <field name="code">model._process_scheduled_messages()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
            <field name="priority">5</field>
            <field name="user_id" ref="base.user_root"/>
        </record>

        <!-- Cron برای حذف خودکار پیام‌ها -->
        <record id="ir_cron_telegram_delete_messages" model="ir.cron">
            <field name="name">حذف خودکار پیام‌های تلگرام</field>
            <field name="model_id" ref="model_telegram_message_delete"/>
            <field name="state">code</field>
            <field name="code">model._cron_delete_messages()</field>
            <field name="interval_number">5</field>
            <field name="interval_type">minutes</field>
            <field name="active" eval="True"/>
            <field name="priority">1</field>
            <field name="user_id" ref="base.user_root"/>
        </record>
    </data>
</odoo> 