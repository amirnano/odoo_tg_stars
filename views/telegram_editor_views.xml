<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_telegram_editor_form" model="ir.ui.view">
        <field name="name">telegram.editor.form</field>
        <field name="model">telegram.editor</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="send_message" 
                            string="ارسال پیام" 
                            type="object" 
                            class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="content" widget="html"/>
                        <field name="preview" readonly="1"/>
                        <field name="attachment_ids" widget="many2many_binary"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_telegram_editor_list" model="ir.ui.view">
        <field name="name">telegram.editor.list</field>
        <field name="model">telegram.editor</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="create_date"/>
            </list>
        </field>
    </record>

    <record id="action_telegram_editor" model="ir.actions.act_window">
        <field name="name">ویرایشگر پیام</field>
        <field name="res_model">telegram.editor</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo> 