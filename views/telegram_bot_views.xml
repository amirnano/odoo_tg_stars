<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <!-- List View -->
    <record id="view_telegram_bot_list" model="ir.ui.view">
        <field name="name">telegram.bot.list</field>
        <field name="model">telegram.bot</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="username"/>
                <field name="is_active"/>
                <field name="created_date"/>
            </list>
        </field>
    </record>

    <!-- Form View -->
    <record id="view_telegram_bot_form" model="ir.ui.view">
        <field name="name">telegram.bot.form</field>
        <field name="model">telegram.bot</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_set_webhook" 
                            string="تنظیم Webhook" 
                            type="object"
                            class="btn-primary"/>
                </header>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="username"/>
                        <field name="api_token" password="True"/>
                        <field name="payment_provider_token" password="True"/>
                        <field name="is_active"/>
                        <field name="description"/>
                        <field name="created_date"/>
                        <field name="webhook_url" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="action_telegram_bot" model="ir.actions.act_window">
        <field name="name">ربات‌های تلگرام</field>
        <field name="res_model">telegram.bot</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                هنوز هیچ رباتی تعریف نشده است.
            </p>
            <p>
                برای افزودن ربات جدید کلیک کنید.
            </p>
        </field>
    </record>
</odoo> 