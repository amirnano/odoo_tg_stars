<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_telegram_log_list" model="ir.ui.view">
        <field name="name">telegram.log.list</field>
        <field name="model">telegram.log</field>
        <field name="arch" type="xml">
            <list string="لاگ‌های تلگرام" create="false">
                <field name="create_date"/>
                <field name="bot_id"/>
                <field name="direction"/>
                <field name="status_code"/>
                <field name="error_message"/>
            </list>
        </field>
    </record>

    <record id="view_telegram_log_form" model="ir.ui.view">
        <field name="name">telegram.log.form</field>
        <field name="model">telegram.log</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="type"/>
                        <field name="bot_id"/>
                        <field name="direction"/>
                        <field name="status_code"/>
                        <field name="error_message"/>
                        <field name="description"/>
                        <field name="request_data"/>
                        <field name="response_data"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_telegram_log" model="ir.actions.act_window">
        <field name="name">لاگ‌های تلگرام</field>
        <field name="res_model">telegram.log</field>
        <field name="view_mode">list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                هنوز هیچ لاگی ثبت نشده است.
            </p>
        </field>
    </record>

    <menuitem id="menu_telegram_log"
              name="لاگ‌ها"
              parent="telegram_base.menu_telegram_root"
              action="action_telegram_log"
              sequence="50"/>
</odoo>