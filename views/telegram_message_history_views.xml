<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_telegram_message_history_list" model="ir.ui.view">
        <field name="name">telegram.message.history.list</field>
        <field name="model">telegram.message.history</field>
        <field name="arch" type="xml">
            <list string="تاریخچه پیام‌ها">
                <field name="create_date" string="تاریخ ارسال"/>
                <field name="partner_id"/>
                <field name="chat_id"/>
                <field name="bot_id"/>
                <field name="state" decoration-success="state == 'sent'" 
                       decoration-danger="state in ('failed', 'blocked')"
                       decoration-warning="state == 'deactivated'"/>
                <field name="error_message"/>
                <field name="message"/>
                <field name="is_success" invisible="1"/>
            </list>
        </field>
    </record>

    <record id="view_telegram_message_history_form" model="ir.ui.view">
        <field name="name">telegram.message.history.form</field>
        <field name="model">telegram.message.history</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <group>
                            <field name="partner_id"/>
                            <field name="bot_id"/>
                            <field name="chat_id"/>
                            <field name="campaign_id" invisible="1"/>
                            <field name="state"/>
                        </group>
                        <group>
                            <field name="create_date" string="تاریخ ارسال"/>
                            <field name="attachment_name"/>
                            <field name="error_message"/>
                        </group>
                    </group>
                    <notebook>
                        <page string="متن پیام">
                            <field name="message"/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_telegram_message_history_search" model="ir.ui.view">
        <field name="name">telegram.message.history.search</field>
        <field name="model">telegram.message.history</field>
        <field name="arch" type="xml">
            <search>
                <field name="partner_id"/>
                <field name="bot_id"/>
                <field name="error_message"/>
                <separator/>
                <filter string="ارسال موفق" name="sent" domain="[('state', '=', 'sent')]"/>
                <filter string="ارسال ناموفق" name="not_sent" domain="[('state', '!=', 'sent')]"/>
                <filter string="بلاک شده" name="blocked" domain="[('state', '=', 'blocked')]"/>
                <filter string="غیرفعال" name="deactivated" domain="[('state', '=', 'deactivated')]"/>
                <filter string="خطا" name="failed" domain="[('state', '=', 'failed')]"/>
                <group expand="0" string="گروه‌بندی">
                    <filter string="وضعیت" name="group_by_state" context="{'group_by': 'state'}"/>
                    <filter string="مخاطب" name="group_by_partner" context="{'group_by': 'partner_id'}"/>
                    <filter string="تاریخ" name="group_by_date" context="{'group_by': 'create_date:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_telegram_message_history" model="ir.actions.act_window">
        <field name="name">تاریخچه پیام‌ها</field>
        <field name="res_model">telegram.message.history</field>
        <field name="view_mode">list,form</field>
        <field name="context">{}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                هنوز هیچ پیامی در تاریخچه ثبت نشده است.
            </p>
        </field>
    </record>

    <menuitem id="menu_telegram_message_history"
              name="تاریخچه پیام‌ها"
              parent="telegram_base.menu_telegram_root"
              action="action_telegram_message_history"
              sequence="20"/>
</odoo> 