<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_telegram_step_option_list" model="ir.ui.view">
        <field name="name">telegram.step.option.list</field>
        <field name="model">telegram.step.option</field>
        <field name="priority" eval="16"/>
        <field name="arch" type="xml">
            <list>
                <field name="sequence" widget="handle"/>
                <field name="step_id"/>
                <field name="text"/>
                <field name="value"/>
                <field name="next_step_id"/>
            </list>
        </field>
    </record>

    <record id="view_telegram_step_option_form" model="ir.ui.view">
        <field name="name">telegram.step.option.form</field>
        <field name="model">telegram.step.option</field>
        <field name="priority" eval="16"/>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="step_id"/>
                        <field name="text"/>
                        <field name="value"/>
                        <field name="next_step_id" domain="[('campaign_id', '=', campaign_id)]"/>
                        <field name="campaign_id" invisible="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_telegram_step_option" model="ir.actions.act_window">
        <field name="name">گزینه‌های مرحله</field>
        <field name="res_model">telegram.step.option</field>
        <field name="view_mode">list,form</field>
    </record>
</odoo> 