<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_telegram_send_direct_message_wizard_form" model="ir.ui.view">
        <field name="name">telegram.send.direct.message.wizard.form</field>
        <field name="model">telegram.send.direct.message.wizard</field>
        <field name="arch" type="xml">
            <form string="ارسال پیام تلگرام">
                <sheet>
                    <group>
                        <field name="partner_id" readonly="1"/>
                        <field name="use_html_format"/>
                        <field name="message" 
                               widget="html" 
                               options="{'style-inline': true}"
                               placeholder="متن پیام را وارد کنید..."/>
                        <field name="attachment" filename="attachment_name"/>
                        <field name="attachment_name" invisible="1"/>
                        <field name="attachment_type" readonly="1"/>
                    </group>
                </sheet>
                <footer>
                    <button string="ارسال" 
                            name="action_send_message" 
                            type="object" 
                            class="btn-primary"/>
                    <button string="انصراف" 
                            class="btn-secondary" 
                            special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

    <!-- اکشن برای ارسال تکی -->
    <record id="action_telegram_send_direct_message" model="ir.actions.act_window">
        <field name="name">ارسال پیام تلگرام</field>
        <field name="res_model">telegram.send.direct.message.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
        <field name="binding_model_id" ref="base.model_res_partner"/>
    </record>
</odoo> 