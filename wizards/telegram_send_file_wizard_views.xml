<?xml version="1.0" encoding="UTF-8"?>
<odoo>
    <record id="view_telegram_send_file_wizard_form" model="ir.ui.view">
        <field name="name">telegram.send.file.wizard.form</field>
        <field name="model">telegram.send.file.wizard</field>
        <field name="arch" type="xml">
            <form string="ارسال فایل">
                <sheet>
                    <group>
                        <field name="bot_id" domain="[('is_active', '=', True)]"/>
                        <field name="partner_id"/>
                        <field name="chat_id" attrs="{'required': [('partner_id', '=', False)]}"/>
                        <field name="file_type"/>
                        <field name="file" filename="filename"/>
                        <field name="filename" invisible="1"/>
                        <field name="caption"/>
                    </group>
                </sheet>
                <footer>
                    <button name="action_send_file" 
                            string="ارسال" 
                            type="object" 
                            class="btn-primary"/>
                    <button special="cancel" 
                            string="انصراف" 
                            class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_telegram_send_file_wizard" model="ir.actions.act_window">
        <field name="name">ارسال فایل تلگرام</field>
        <field name="res_model">telegram.send.file.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>
</odoo> 